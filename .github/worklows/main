name: Android CI Build

# This repository does NOT commit a Gradle wrapper (no `gradlew` /
# `gradlew.bat` / `gradle/wrapper/`), per project convention. This workflow
# therefore installs the exact Gradle version the project targets (8.7)
# directly via `wget` and invokes the `gradle` binary directly, instead of
# `./gradlew`.

on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]
  workflow_dispatch:

env:
  GRADLE_VERSION: "8.7"

jobs:
  build:
    name: Build debug APK
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: "temurin"
          java-version: "17"

      # No gradlew in the repo — install Gradle 8.7 manually.
      - name: Install Gradle ${{ env.GRADLE_VERSION }}
        run: |
          wget -q "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" -O /tmp/gradle.zip
          sudo unzip -q -d /opt/gradle /tmp/gradle.zip
          echo "/opt/gradle/gradle-${GRADLE_VERSION}/bin" >> "$GITHUB_PATH"

      - name: Verify Gradle installation
        run: gradle --version

      - name: Set up Android SDK
        uses: android-actions/setup-android@v3

      - name: Cache Gradle caches
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: gradle-${{ runner.os }}-${{ hashFiles('**/*.gradle*', '**/gradle.properties') }}
          restore-keys: |
            gradle-${{ runner.os }}-

      - name: Build debug APK
        run: gradle assembleDebug --stacktrace --no-daemon

      - name: Run unit tests
        run: gradle testDebugUnitTest --stacktrace --no-daemon
        continue-on-error: true

      - name: Upload debug APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: landscape-design-debug-apk
          path: app/build/outputs/apk/debug/*.apk
          if-no-files-found: error
