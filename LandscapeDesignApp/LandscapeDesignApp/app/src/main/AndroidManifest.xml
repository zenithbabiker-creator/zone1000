package com.example.landscapedesign.ar

import android.content.Context
import android.util.Log
import androidx.compose.runtime.*

class ARSessionManager(private val context: Context) {
    var isArSupported by mutableStateOf(true)
        private set

    init {
        checkArAvailability()
    }

    private fun checkArAvailability() {
        try {
            // التحقق المبدئي لدعم بيئة الـ AR بناءً على المكتبة المفعلة في الـ Flavor
            Log.d("ARSessionManager", "AR Environment Initialized Successfully.")
            isArSupported = true
        } catch (e: Exception) {
            Log.e("ARSessionManager", "AR not supported on this device", e)
            isArSupported = false
        }
    }
}
